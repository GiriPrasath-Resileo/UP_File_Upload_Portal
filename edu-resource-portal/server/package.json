{
  "name": "@edu-portal/server",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=json-summary --coverageReporters=text --coverageReporters=lcov"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@prisma/client": "^5.11.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "@edu-portal/shared": "*",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
